// VSCodium settings for vscode-neovim integration
// Copy to ~/Library/Application Support/VSCodium/User/settings.json
// or manage via nix-darwin home-manager programs.vscode.userSettings
{
  // ============================================================
  // vscode-neovim
  // ============================================================
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
  "vscode-neovim.neovimInitVimPaths.darwin": "~/.config/nvim/init.lua",
  "vscode-neovim.useCtrlKeysForNormalMode": true,
  "vscode-neovim.useCtrlKeysForInsertMode": false,
  // ============================================================
  // clangd (C++ — replaces mason + astrolsp clangd config)
  // ============================================================
  "clangd.path": "clangd",
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--header-insertion=iwyu",
    "--completion-style=detailed",
    "--function-arg-placeholders",
    "--fallback-style=llvm",
    "--query-driver=/usr/bin/c++,/usr/bin/g++,/usr/bin/clang++"
  ],
  // ============================================================
  // Editor behavior (matching astrocore options)
  // ============================================================
  "editor.lineNumbers": "on",
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.inlayHints.enabled": "on",
  "editor.semanticHighlighting.enabled": true,
  // Disable format-on-save for C/C++ (matches astrolsp ignore_filetypes)
  "[cpp]": {
    "editor.formatOnSave": false
  },
  "[c]": {
    "editor.formatOnSave": false
  },
  "[cuda-cpp]": {
    "editor.formatOnSave": false
  },
  // ============================================================
  // Theme (matching astroui colorscheme)
  // ============================================================
  "workbench.colorTheme": "Catppuccin Macchiato",
  // ============================================================
  // Recommended extensions for parity
  // ============================================================
  // Install via CLI:
  //   codium --install-extension asvetliakov.vscode-neovim
  //   codium --install-extension llvm-vs-code-extensions.vscode-clangd
  //   codium --install-extension vadimcn.vscode-lldb
  //   codium --install-extension eamodio.gitlens
  //   codium --install-extension catppuccin.catppuccin-vsc
  //   codium --install-extension ms-vscode.cpptools
  //   codium --install-extension usernamehw.errorlens
  // ============================================================
  // Debugger (CodeLLDB — replaces nvim-dap)
  // ============================================================
  "lldb.verboseLogging": false
}