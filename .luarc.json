{
  "$schema": "https://githubusercontent.com",
  "Lua.format.defaultConfig": {
    "indent_style": "space",
    "indent_size": "2",
    "continuation_indent_size": "2",
    "max_line_length": "120",
    "quote_style": "single",
    "line_space_after_expression_statement": "keep",
    "call_arg_parentheses": "always"
  }
}

